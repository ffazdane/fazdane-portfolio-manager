# ============================================================
# tastytrade OAuth2 Credentials
# ============================================================
# How to get these — go to my.tastytrade.com → My Profile → API → OAuth Applications → Manage:
#
#   TT_CLIENT_ID  = The "CLIENT ID" UUID shown on the Manage page
#   TT_SECRET     = The "CLIENT SECRET" — click "Regenerate" if you lost it
#   TT_REFRESH    = Scroll to the bottom of the Manage page → click "Create Grant"
#
# All three are required for OAuth2 authentication.

TT_CLIENT_ID=your_client_id_uuid_here
TT_SECRET=your_client_secret_here
TT_REFRESH=your_refresh_token_here

# Environment: production or sandbox
TASTYTRADE_ENVIRONMENT=production
