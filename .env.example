# ============================================================
# tastytrade OAuth2 Credentials
# ============================================================
# How to get these:
# 1. Go to my.tastytrade.com → My Profile → API → OAuth Applications
# 2. Click "Manage" on your app
# 3. Client Secret is shown at the top
# 4. Click "Create Grant" to generate your Refresh Token

TT_SECRET=your_client_secret_here
TT_REFRESH=your_refresh_token_here

# Environment: production or sandbox
TASTYTRADE_ENVIRONMENT=production
