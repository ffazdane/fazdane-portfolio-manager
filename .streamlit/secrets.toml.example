# ============================================================
# Streamlit Secrets — Example Configuration
# ============================================================
# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit the real file.
#
# Official docs: https://docs.streamlit.io/library/advanced-features/secrets-management
# ============================================================

# ── Tastytrade API ───────────────────────────────────────────
TT_CLIENT_ID = "your_client_id_uuid_here"
TT_SECRET    = "your_client_secret_here"
TT_REFRESH   = "your_refresh_token_here"

# ── Database Persistence ─────────────────────────────────────
# Controls where portfolio.db is backed up / restored from.
# Set backend = "none" for local development (no remote backup).
# Use "github" (recommended) or "s3" for Streamlit Cloud.

[database]
backend = "github"   # "none" | "github" | "s3"

# ── GitHub Backend (Recommended for Streamlit Cloud) ─────────
# The database is stored as a Release asset in your GitHub repo.
# No extra cloud accounts needed — just a Personal Access Token.
#
# How to create a GitHub PAT:
#   GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
#   Required permissions: Contents (read & write), Deployments (read)
#
[database.github]
token = "ghp_your_personal_access_token_here"
owner = "your-github-username"
repo  = "fazdane-portfolio-manager"
tag   = "db-backup"    # GitHub Release tag used as the database store

# ── S3 Backend (Alternative) ─────────────────────────────────
# Use this if you prefer AWS S3 or an S3-compatible store (Cloudflare R2, MinIO, etc.)
# Leave blank if using the GitHub backend above.
#
# [database.s3]
# bucket            = "your-bucket-name"
# key               = "portfolio/portfolio.db"
# region            = "us-east-1"
# access_key_id     = "AKIA..."       # optional if using IAM role
# secret_access_key = "..."
